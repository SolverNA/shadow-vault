{
  "name": "you-encrypt",
  "version": "1.0.0",
  "description": "Transparent AES-256-GCM encryption plugin for Obsidian via VFS adapter monkey-patching",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "build:plugin": "npm run build && node scripts/package-plugin.mjs",
    "test": "jest"
  },
  "keywords": [
    "obsidian",
    "encryption",
    "vault"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "builtin-modules": "^5.1.0",
    "esbuild": "0.17.3",
    "jest": "^29.7.0",
    "obsidian": "^1.12.3",
    "ts-jest": "^29.4.9",
    "typescript": "^4.7.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
